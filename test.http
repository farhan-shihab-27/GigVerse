### ============================================================
### GigVerse API — REST Client Test File
### Use with VS Code "REST Client" extension (humao.rest-client)
### ============================================================
### Variables — update these after seeding
@baseUrl = http://localhost:5000/api
@clientId = 1
@contributor1 = 2
@contributor2 = 3
@gigId = 1
@orderId = 1
### ⚠️  Paste the JWT token from the login response below:
@token = PASTE_YOUR_JWT_TOKEN_HERE


### ─────────────────────────────────────────────────────────────
### HEALTH CHECK
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/health HTTP/1.1


### ─────────────────────────────────────────────────────────────
### AUTH — Register a new user
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/auth/register HTTP/1.1
Content-Type: application/json

{
  "name": "Test User",
  "uiuEmail": "test.user@bss.uiu.ac.bd",
  "personalEmail": "testuser@gmail.com",
  "password": "Secure@9876",
  "roleId": 1,
  "deptId": 1,
  "dob": "2003-01-15"
}


### ─────────────────────────────────────────────────────────────
### AUTH — Register with INVALID email (should fail)
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/auth/register HTTP/1.1
Content-Type: application/json

{
  "name": "Bad Email User",
  "uiuEmail": "bad.email@gmail.com",
  "personalEmail": "another@gmail.com",
  "password": "Pass1234",
  "roleId": 1,
  "deptId": 1
}


### ─────────────────────────────────────────────────────────────
### AUTH — Login (with UIU email) → copy the token from response
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "nadia.sultana@bss.uiu.ac.bd",
  "password": "Test@1234"
}


### ─────────────────────────────────────────────────────────────
### AUTH — Login (with personal email) → also works
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "rafiq.personal@gmail.com",
  "password": "Test@1234"
}


### ─────────────────────────────────────────────────────────────
### DASHBOARD — Platform stats
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/dashboard/stats HTTP/1.1


### ─────────────────────────────────────────────────────────────
### USERS — Get public profile (Contributor 1)
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/users/{{contributor1}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### USERS — Update profile
### ─────────────────────────────────────────────────────────────

PUT {{baseUrl}}/users/{{contributor1}} HTTP/1.1
Content-Type: application/json

{
  "bio": "Updated bio: Senior full-stack developer & designer.",
  "profilePicUrl": "https://example.com/nadia-avatar.jpg"
}


### ─────────────────────────────────────────────────────────────
### USERS — Set skills for a user
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/users/{{contributor1}}/skills HTTP/1.1
Content-Type: application/json

{
  "skillIds": [1, 2, 3]
}


### ─────────────────────────────────────────────────────────────
### USERS — Get private info (protected route)
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/users/{{contributor1}}/private HTTP/1.1


### ─────────────────────────────────────────────────────────────
### USERS — Update private info
### ─────────────────────────────────────────────────────────────

PUT {{baseUrl}}/users/{{contributor1}}/private HTTP/1.1
Content-Type: application/json

{
  "whatsAppNumber": "+8801799999999",
  "bkashNumber": "01799999999",
  "bankAccountDetails": "Sonali Bank, Acc: 1234567890, Branch: Dhanmondi"
}


### ─────────────────────────────────────────────────────────────
### USERS — Leaderboard (top PVP)
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/users/leaderboard?limit=10 HTTP/1.1


### ─────────────────────────────────────────────────────────────
### SEARCH — Find contributors by skill name
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/search/contributors?skill=Logo HTTP/1.1


### ─────────────────────────────────────────────────────────────
### SEARCH — Find contributors by skill (Web Development)
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/search/contributors?skill=Web+Development HTTP/1.1


### ─────────────────────────────────────────────────────────────
### SEARCH — List all available skills
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/search/skills HTTP/1.1


### ─────────────────────────────────────────────────────────────
### GIGS — Create a new gig (🔒 Requires JWT)
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/gigs HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "contributorId": {{contributor2}},
  "title": "Instagram Marketing Package",
  "description": "Full month of Instagram content strategy, posts, and analytics.",
  "basePrice": 1500.00
}


### ─────────────────────────────────────────────────────────────
### GIGS — Get all gigs (ranked by PVP)
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/gigs HTTP/1.1


### ─────────────────────────────────────────────────────────────
### GIGS — Get single gig
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/gigs/{{gigId}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### GIGS — Get gigs by contributor
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/gigs/user/{{contributor1}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### ORDERS — Create order (🔒 Requires JWT)
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/orders HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "clientId": {{clientId}},
  "gigId": {{gigId}}
}


### ─────────────────────────────────────────────────────────────
### ORDERS — Get order details
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/orders/{{orderId}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### ORDERS — Update order status (🔒 Requires JWT)
### ─────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/orders/{{orderId}}/status HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "orderStatus": "Completed",
  "paymentStatus": "Released"
}


### ─────────────────────────────────────────────────────────────
### ORDERS — Get all orders for a user
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/orders/user/{{clientId}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### REVIEWS — Submit a 5-star review (🔒 Requires JWT)
### ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "orderId": {{orderId}},
  "reviewerId": {{clientId}},
  "rating": 5,
  "comment": "Absolutely outstanding logo work! Exceeded expectations."
}


### ─────────────────────────────────────────────────────────────
### REVIEWS — Get review for a specific order
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/reviews/order/{{orderId}} HTTP/1.1


### ─────────────────────────────────────────────────────────────
### REVIEWS — Get all reviews for a contributor
### ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/reviews/user/{{contributor1}} HTTP/1.1
